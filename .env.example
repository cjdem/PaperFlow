# ==================== 数据库配置 ====================
# 数据库连接字符串，用于配置数据持久化存储

# 本地开发：使用 SQLite（默认，无需配置，存储到项目 data 目录）
DB_URL=sqlite:///data/papers.db

# ==================== 认证配置 ====================
# JWT 密钥（必须配置，建议使用 32+ 位随机字符串）
JWT_SECRET_KEY=change-me-to-a-strong-secret

# 生产环境：使用 PostgreSQL（推荐）
# 部署到云平台时，请在平台的环境变量/Secrets 中配置以下格式：
# DB_URL=postgresql://username:password@host:port/database

# ==================== 文件存储配置 ====================
# PDF 文件存储路径（相对于项目根目录）
# 默认值：runtime/uploads（系统会自动使用 runtime/uploads/papers）
FILE_STORAGE_PATH=runtime/uploads

# ==================== 前端 API 配置 ====================
# 本地开发默认使用 http://localhost:8000，可不配置。
# PAPERFLOW_BACKEND_URL 用于 Next.js 服务端 rewrite；NEXT_PUBLIC_API_URL 会暴露给浏览器。
# PAPERFLOW_BACKEND_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# 用户存储配额（单位：MB）
STORAGE_QUOTA_MB=2048

# 最大文件大小（字节），默认 50MB
# MAX_FILE_SIZE=52428800

# 允许的文件扩展名（逗号分隔）
# ALLOWED_EXTENSIONS=.pdf

# ==================== PDF 翻译配置 ====================
# 翻译队列配置
TRANSLATION_MAX_CONCURRENT=2          # 最大并发翻译任务数
TRANSLATION_RETRY_MAX=3               # 失败重试次数
TRANSLATION_RETRY_DELAY=60            # 重试间隔（秒）
TRANSLATION_RETRY_BACKOFF=2.0         # 重试间隔倍增系数
TRANSLATION_TASK_TIMEOUT=30           # 单任务超时时间（分钟）

# PDF 翻译参数
TRANSLATION_MAX_PAGES_PER_PART=50     # 分片大小（页数）
TRANSLATION_QPS=4                     # 每秒请求数限制
TRANSLATION_LANG_IN=en                # 源语言
TRANSLATION_LANG_OUT=zh               # 目标语言

# ==================== 日志配置 ====================
LOG_DIR=runtime/logs
LOG_FILE=paperflow.log
LOG_LEVEL=INFO
LOG_ENABLED=true
